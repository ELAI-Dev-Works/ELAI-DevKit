    <section name="Tooltips">
        <key name="packer_extensions_tooltip">File extensions to include in the pack, space or comma separated. e.g. .py .txt .md</key>
        <key name="packer_one_file_tooltip">Merges the directory tree and file contents into a single .txt file.</key>
        <key name="packer_timestamp_tooltip">Adds a timestamp at the beginning of the file.</key>
        <key name="packer_split_tooltip">Automatically splits the output into multiple files if size exceeds 999KB.</key>
        <key name="packer_select_output_dir_tooltip">Choose the directory where the packed text files will be saved.</key>
        <key name="packer_start_tooltip">Begin the process of scanning, building, and packing the project files.</key>
    </section>
    <section name="Standalone">
        <key name="project_text_packer_standalone_title">Project Text Packer (Standalone)</key>
    </section>
