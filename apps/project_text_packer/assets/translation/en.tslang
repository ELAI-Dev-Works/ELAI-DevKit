        <key name="packer_timestamp_checkbox">Add Date &amp; Time</key>
        <key name="packer_split_checkbox">Split into parts (limit 1MB)</key>
        <key name="patch_load_error_title">Error</key>
        <key name="project_folder_missing_error">ERROR: Project folder (@ROOT) is not selected!</key>
        <key name="quick_settings_saved_log">[Settings] Quick settings saved.</key>
        <key name="quick_settings_reset_log">[Settings] Quick settings have been reset to default (not saved).</key>
