    <section name="Standalone">
        <key name="dev_patcher_standalone_title">Dev Patcher (Autonome)</key>
    </section>
    <section name="Dialogs">
        <key name="patch_load_error_title">Erreur</key>
        <key name="patch_load_error_msg">Échec de la lecture du fichier de correctif : {}</key>
        <key name="self_update_warning_title">Attention !</key>
        <key name="self_update_warning_msg">Ce correctif est destiné à modifier les fichiers de l'application DevPatcher. Êtes-vous sûr de vouloir continuer ?</key>
        <key name="error_report_title">Rapport d'erreur</key>
        <key name="error_report_msg">Certaines commandes n'ont pas pu être exécutées. Vous pouvez copier leur contenu pour une correction manuelle.</key>
        <key name="copy_report_btn">Copier le rapport</key>
        <key name="close_btn_accept">Fermer</key>
        <key name="simulation_confirm_title">Confirmation</key>
        <key name="simulation_success_msg">Simulation terminée. Appliquer ce correctif aux fichiers réels ?</key>
        <key name="simulation_error_msg">Des erreurs ou conflits ont été détectés pendant la simulation ! Les détails sont dans le journal. Tenter d'appliquer le correctif quand même ?</key>
        <key name="test_run_report_title">Rapport d'exécution de test</key>
        <key name="test_run_report_info">Ceci est la sortie console du lancement de test de votre application corrigée.</key>
        <key name="code_check_error_msg">Erreurs de syntaxe détectées dans le code corrigé ! Consultez le rapport pour plus de détails. Tenter d'appliquer le correctif quand même ?</key>
        <key name="corrector_title">Correcteur de syntaxe de correctif</key>
        <key name="corrector_info_label">Des erreurs de syntaxe ou suggestions ont été trouvées dans votre correctif. Examinez les modifications ci-dessous.</key>
        <key name="corrector_issue_label">Problème</key>
        <key name="corrector_apply_fix_btn">Appliquer cette correction</key>
        <key name="corrector_applied_btn">Appliqué</key>
        <key name="corrector_apply_all_btn">Appliquer toutes les corrections</key>
        <key name="corrector_accept_btn">Accepter les corrections</key>
        <key name="corrector_cancel_btn">Annuler</key>
        <key name="corrector_suggestion_title">Suggestion</key>
        <key name="corrector_suggestion_info">Ceci est une suggestion. Pour l'appliquer, veuillez modifier le paramètre correspondant dans le panneau 'Paramètres rapides'.</key>
        <key name="corrector_suggestion_no_change">Aucune modification de texte n'est suggérée pour cet élément. Il s'agit d'une recommandation de modifier les paramètres de l'application pour que le correctif fonctionne comme prévu.</key>
        <key name="corrector_acknowledge_btn">Confirmer</key>
        <key name="corrector_acknowledged_btn">Confirmé</key>
        <key name="corrector_enable_scope_btn">Activer la correspondance de portée</key>
        <key name="corrector_enable_lineno_btn">Activer le correctif précis</key>
        <key name="corrector_feature_enabled_msg_title">Fonctionnalité activée</key>
        <key name="corrector_feature_enabled_msg_text">La fonctionnalité requise a été activée et enregistrée dans les Paramètres rapides.</key>
        <key name="corrector_project_name_error">Format invalide. Le nom du projet doit être entre chevrons, par exemple &lt;Mon Projet&gt;</key>
        <key name="restore_modal_title">Restaurer depuis la sauvegarde</key>
        <key name="restore_no_backups">Aucune sauvegarde disponible.</key>
        <key name="restore_confirm_msg">Êtes-vous sûr de vouloir restaurer le projet depuis cette sauvegarde/commit ? Les modifications non enregistrées seront perdues.</key>
        <key name="restore_success_msg">Restauration terminée avec succès !</key>
        <key name="restore_error_msg">Échec de la restauration du projet : {}</key>
    </section>
    <section name="Tooltips">
        <key name="load_patch_tooltip">Charger un fichier .devpatch depuis votre ordinateur dans l'éditeur.</key>
        <key name="examples_tooltip">Parcourir et charger les exemples de correctifs officiels.</key>
        <key name="correct_patch_tooltip">Analyser le correctif pour détecter les erreurs de syntaxe et suggérer des corrections automatiques.</key>
        <key name="check_patch_tooltip">Exécuter une simulation complète pour vérifier les conflits et erreurs avant l'application.</key>
        <key name="check_code_tooltip">Simuler le correctif puis effectuer une vérification syntaxique du code modifié.</key>
        <key name="test_run_tooltip">Simuler le correctif puis tenter d'exécuter le fichier de lancement du projet pour tester les erreurs d'exécution.</key>
        <key name="execute_patch_tooltip">Exécuter le flux complet (sauvegarde, simulation, application) pour modifier les fichiers du projet.</key>
        <key name="precise_patching_tooltip">Permet d'utiliser les numéros de ligne dans le correctif pour plus de précision, qui seront supprimés lors de l'application.</key>
        <key name="fuzzy_matching_tooltip">Recherche le bloc le plus similaire au lieu d'une correspondance exacte. Utile si des modifications mineures ont été apportées au code.</key>
        <key name="scope_matching_tooltip">Restreint la recherche du bloc ---old--- dans un bloc ---scope--- plus large, résolvant le problème des doublons.</key>
        <key name="similarity_threshold_tooltip">Définit le pourcentage de similarité minimum requis (1-100) pour qu'une correspondance approximative soit considérée comme réussie.</key>
        <key name="corrector_checkbox_tooltip">Exécuter automatiquement le correcteur de patch avant la simulation et l'exécution.</key>
        <key name="simulation_checkbox_tooltip">Effectuer une simulation à blanc avant l'exécution pour prévisualiser les modifications et détecter les conflits.</key>
        <key name="code_check_checkbox_tooltip">Après une simulation réussie, vérifier la syntaxe des fichiers modifiés (par ex. Python, JSON).</key>
        <key name="test_run_checkbox_tooltip">Après une vérification de code réussie, tenter de lancer le projet pour tester les erreurs d'exécution.</key>
        <key name="restore_refresh_tooltip">Actualiser la liste des sauvegardes disponibles.</key>
    </section>
</tslang>