        <key name="backup_commit_msg_placeholder">Повідомлення коміту...</key>
        <key name="init_git_btn">Ініціалізувати репозиторій</key>
        <key name="save_quick_settings_btn">Зберегти налаштування</key>
        <key name="execute_patch_btn">Застосувати патч</key>
        <key name="check_patch_btn">Перевірити патч</key>
        <key name="check_code_btn">Перевірити код</key>
        <key name="correct_patch_btn">Виправити патч</key>
        <key name="test_run_btn">Тестовий запуск</key>
        <key name="load_patch_btn">Завантажити патч...</key>
        <key name="examples_btn">Приклади</key>
