        <key name="patcher_log_placeholder">Результати виконання патчера будуть тут...</key>
        <key name="context_wrap_raw">Обернути в пряме виконання ({!RUN})</key>
        <key name="restore_mode_changes">Тільки зміни (стандартний)</key>
        <key name="restore_mode_full">Повна заміна (застарілий)</key>
