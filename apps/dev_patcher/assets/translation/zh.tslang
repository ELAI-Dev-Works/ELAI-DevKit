        <key name="self_update_warning_msg">此补丁旨在修改 DevPatcher 应用程序文件。确定要继续吗？</key>
        <key name="error_report_title">错误报告</key>
        <key name="error_report_msg">某些命令无法执行。您可以复制其内容进行手动修正。</key>
        <key name="copy_report_btn">复制报告</key>
        <key name="close_btn_accept">关闭</key>
        <key name="simulation_confirm_title">确认</key>
        <key name="test_run_report_title">测试运行报告</key>
        <key name="test_run_report_info">这是已修补应用程序的测试启动的控制台输出。</key>
        <key name="corrector_title">补丁语法修正器</key>
        <key name="corrector_info_label">在您的补丁中发现语法错误或建议。查看下面的更改。</key>
        <key name="corrector_issue_label">问题</key>
        <key name="corrector_apply_fix_btn">应用此修复</key>
        <key name="corrector_applied_btn">已应用</key>
        <key name="corrector_apply_all_btn">应用所有修复</key>
