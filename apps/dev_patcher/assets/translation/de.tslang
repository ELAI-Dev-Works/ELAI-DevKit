        <key name="simulation_start_log">--- ERWEITERTE SIMULATION GESTARTET ---</key>
        <key name="simulation_end_log">--- ERWEITERTE SIMULATION BEENDET ---</key>
        <key name="code_check_start_log">--- CODEPRÜFUNG GESTARTET ---</key>
        <key name="code_check_finished_log">--- CODEPRÜFUNG BEENDET ---</key>
        <key name="code_check_running_log">[Codeprüfung] Überprüfe Syntax des gepatchten Codes...</key>
        <key name="code_check_errors_found_log">[Codeprüfung] Syntaxfehler gefunden!</key>
        <key name="code_check_no_errors_log">[Codeprüfung] Keine Syntaxfehler gefunden.</key>
        <key name="corrector_done_log">[Korrektor] Korrektur abgeschlossen.</key>
        <key name="corrector_no_issues_log">[Korrektor] Keine Probleme gefunden.</key>
        <key name="corrector_issues_found_log">[Korrektor] Probleme gefunden. Öffne Korrekturdialog...</key>
        <key name="corrector_patch_updated_log">[Korrektor] Patch wurde mit Korrekturen aktualisiert.</key>
        <key name="corrector_cancelled_log">[Korrektor] Korrektur vom Benutzer abgebrochen. Ausführung wird angehalten.</key>
        <key name="correction_whitespace_marker">Der Marker hat führende Leerzeichen. Er sollte am Zeilenanfang stehen.</key>
        <key name="correction_enable_scope">Ein '---scope---'-Block wurde gefunden, aber 'Scope Matching' ist in den Schnelleinstellungen nicht aktiviert.</key>
        <key name="correction_enable_lineno">Zeilennummern wurden gefunden, aber 'Precise Patching' ist in den Schnelleinstellungen nicht aktiviert.</key>
        <key name="correction_manage_order">Die Reihenfolge der Argumente scheint falsch zu sein. Das Flag (z.B. -create) sollte vor dem Pfad stehen.</key>
        <key name="correction_edit_missing_new">Der Befehl verwendet -replace oder -insert, aber ein '---new---'-Block fehlt.</key>
        <key name="correction_edit_remove_has_new">Der Befehl verwendet -remove, aber ein '---new---'-Block wurde gefunden und wird nicht benötigt.</key>
        <key name="correction_project_missing_name">Das -name-Argument für PROJECT ist vorhanden, aber der Name selbst fehlt oder ist fehlerhaft. Er muss im Format &lt;...&gt; sein.</key>
        <key name="correction_manage_search_missing_keywords">Dem MANAGE -search-Befehl fehlen Schlüsselwörter im Format &lt;...&gt;.</key>
        <key name="correction_project_missing_run">Der PROJECT-Befehl muss das erforderliche Argument -run &lt;launch_file&gt; enthalten.</key>
        <key name="correction_project_missing_requi">Der PROJECT-Befehl muss das erforderliche Argument -requi &lt;dependencies&gt; enthalten.</key>
        <key name="log_cleared">========================================</key>
        <key name="pl_no_settings_label">Für diese Erweiterung sind noch keine Einstellungen verfügbar.</key>
        <key name="example_patch_loaded">Beispiel-Patch geladen.</key>
        <key name="app_target_name">Anwendung</key>
        <key name="simulation_no_commands">Keine Befehle zum Simulieren.</key>
        <key name="simulation_stage1_start">--- PHASE 1: BASISZUSTAND ERSTELLEN ---</key>
        <key name="simulation_stage1_end">Basiszustand im Speicher erstellt.</key>
        <key name="simulation_stage2_start">--- PHASE 2: EINZELPRÜFUNG (auf Basis) ---</key>
        <key name="simulation_pass1_result">[DURCHLAUF 1] EDIT-Befehl {}/{} ({}): {}</key>
        <key name="simulation_stage3_start">--- PHASE 3: STAPELPRÜFUNG (vollständiger Patch) ---</key>
        <key name="simulation_pass2_result">[DURCHLAUF 2] EDIT-Befehl {}/{} ({}): {}</key>
        <key name="simulation_final_ok">[ABSCHLUSS] Keine Konflikte erkannt. Der Patch sieht sicher aus.</key>
        <key name="simulation_final_warn">[ABSCHLUSS] WARNUNG! Konflikte oder Fehler erkannt. Der Patch lässt sich möglicherweise nicht vollständig anwenden.</key>
        <key name="simulation_success">ERFOLG</key>
        <key name="simulation_fail">FEHLER</key>
        <key name="quick_settings_applied_log">[Einstellungen] Schnelleinstellungen angewendet.</key>
        <key name="test_run_env_required_error">Das Projekt wird mit dem PROJECT-Befehl initialisiert oder benötigt eine Umgebung (.venv, node_modules), die jedoch noch nicht initialisiert wurde. Bitte wenden Sie den Patch an, um die Umgebung zu initialisieren, bevor Sie einen Testlauf durchführen.</key>
    </section>
    <section name="Standalone">
        <key name="dev_patcher_standalone_title">Dev Patcher (Standalone)</key>
    </section>
    <section name="Dialogs">
        <key name="patch_load_error_title">Fehler</key>
        <key name="patch_load_error_msg">Patch-Datei konnte nicht gelesen werden: {}</key>
        <key name="self_update_warning_title">Warnung!</key>
        <key name="self_update_warning_msg">Dieser Patch ist dazu bestimmt, die DevPatcher-Anwendungsdateien zu ändern. Möchten Sie wirklich fortfahren?</key>
        <key name="error_report_title">Fehlerbericht</key>
        <key name="error_report_msg">Einige Befehle konnten nicht ausgeführt werden. Sie können deren Inhalt für eine manuelle Korrektur kopieren.</key>
        <key name="copy_report_btn">Bericht kopieren</key>
        <key name="close_btn_accept">Schließen</key>
        <key name="simulation_confirm_title">Bestätigung</key>
        <key name="test_run_report_title">Testlauf-Bericht</key>
        <key name="test_run_report_info">Dies ist die Konsolenausgabe vom Teststart Ihrer gepatchten Anwendung.</key>
        <key name="corrector_title">Patch-Syntaxkorrektor</key>
        <key name="corrector_info_label">In Ihrem Patch wurden Syntaxfehler oder Vorschläge gefunden. Überprüfen Sie die folgenden Änderungen.</key>
        <key name="corrector_issue_label">Problem</key>
        <key name="corrector_apply_fix_btn">Diese Korrektur anwenden</key>
        <key name="corrector_applied_btn">Angewendet</key>
        <key name="corrector_apply_all_btn">Alle Korrekturen anwenden</key>
        <key name="corrector_accept_btn">Korrekturen akzeptieren</key>
        <key name="corrector_cancel_btn">Abbrechen</key>
        <key name="corrector_suggestion_title">Vorschlag</key>
        <key name="corrector_suggestion_info">Dies ist ein Vorschlag. Um ihn anzuwenden, ändern Sie bitte die entsprechende Einstellung im Panel 'Schnelleinstellungen'.</key>
        <key name="corrector_suggestion_no_change">Für dieses Element werden keine Textänderungen vorgeschlagen. Dies ist eine Empfehlung, die Anwendungseinstellungen zu ändern, damit der Patch wie vorgesehen funktioniert.</key>
        <key name="corrector_acknowledge_btn">Bestätigen</key>
        <key name="corrector_acknowledged_btn">Bestätigt</key>
        <key name="corrector_enable_scope_btn">Bereichsabgleich aktivieren</key>
        <key name="corrector_enable_lineno_btn">Präzises Patchen aktivieren</key>
        <key name="corrector_feature_enabled_msg_title">Funktion aktiviert</key>
        <key name="corrector_feature_enabled_msg_text">Die erforderliche Funktion wurde aktiviert und in den Schnelleinstellungen gespeichert.</key>
        <key name="corrector_project_name_error">Ungültiges Format. Der Projektname muss in spitzen Klammern stehen, z.B. &lt;Mein Projekt&gt;</key>
        <key name="restore_modal_title">Aus Backup wiederherstellen</key>
        <key name="restore_no_backups">Keine Backups verfügbar.</key>
        <key name="restore_confirm_msg">Sind Sie sicher, dass Sie das Projekt aus diesem Backup/Commit wiederherstellen möchten? Nicht gespeicherte Änderungen gehen verloren.</key>
        <key name="restore_success_msg">Wiederherstellung erfolgreich abgeschlossen!</key>
        <key name="restore_error_msg">Projekt konnte nicht wiederhergestellt werden: {}</key>
        <key name="ai_report_dialog_title">KI-Korrekturbericht</key>
        <key name="ai_report_dialog_info">Im Patch wurden problematische Befehle gefunden. Sie werden übersprungen, und der Patch kann sicher angewendet werden. Ein Korrekturbericht für die KI wurde erstellt. Kopieren Sie ihn zusammen mit dem neuen Projektkontext und senden Sie ihn an die KI, damit sie den korrekten Befehl schreiben kann.</key>
        <key name="ai_report_task">Beheben Sie nur das/die angegebene(n) Problem(e).</key>
        <key name="simulation_success_msg_new">Die Simulation ist abgeschlossen. Keine Fehler gefunden. Alle Befehle können sicher ausgeführt werden.</key>
    </section>
    <section name="Tooltips">
        <key name="load_patch_tooltip">Laden Sie eine .devpatch-Datei von Ihrem Computer in den Editor.</key>
        <key name="examples_tooltip">Durchsuchen und laden Sie offizielle Patch-Beispiele.</key>
        <key name="correct_patch_tooltip">Analysieren Sie den Patch auf Syntaxfehler und schlagen Sie automatische Korrekturen vor.</key>
        <key name="check_patch_tooltip">Führen Sie eine vollständige Simulation durch, um vor der Anwendung nach Konflikten und Fehlern zu suchen.</key>
        <key name="check_code_tooltip">Simulieren Sie den Patch und führen Sie dann eine Syntaxprüfung des geänderten Codes durch.</key>
        <key name="test_run_tooltip">Simulieren Sie den Patch und versuchen Sie dann, die Startdatei des Projekts auszuführen, um auf Laufzeitfehler zu testen.</key>
        <key name="execute_patch_tooltip">Führen Sie den vollständigen Workflow (Sicherung, Simulation, Anwendung) aus, um die Projektdateien zu ändern.</key>
        <key name="precise_patching_tooltip">Ermöglicht die Verwendung von Zeilennummern im Patch für mehr Genauigkeit, die bei der Anwendung entfernt werden.</key>
        <key name="fuzzy_matching_tooltip">Sucht nach dem ähnlichsten Block anstelle einer exakten Übereinstimmung. Hilft, wenn kleinere Änderungen am Code vorgenommen wurden.</key>
        <key name="scope_matching_tooltip">Beschränkt die Suche nach dem ---old--- Block innerhalb eines größeren ---scope--- Blocks und löst das Problem mit Duplikaten.</key>
        <key name="similarity_threshold_tooltip">Legt den minimal erforderlichen Ähnlichkeitsprozentsatz (1-100) fest, damit eine unscharfe Übereinstimmung als erfolgreich gilt.</key>
        <key name="restore_refresh_tooltip">Liste der verfügbaren Sicherungen aktualisieren.</key>
        <key name="manual_backup_tooltip">Backup basierend auf aktuellen Einstellungen manuell auslösen.</key>
        <key name="commit_msg_maximize_tooltip">Lange Commit-Nachricht bearbeiten</key>
    </section>
</tslang>