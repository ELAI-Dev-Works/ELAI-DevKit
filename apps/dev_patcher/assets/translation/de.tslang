        <key name="update_complete_title">Update abgeschlossen</key>
        <key name="update_complete_msg">Die Anwendung wurde erfolgreich aktualisiert. Klicken Sie auf OK, um neu zu starten.</key>
        <key name="patch_command_log">[Befehl {}/{}]</key>
        <key name="patch_command_error_log">FEHLER: {}</key>
