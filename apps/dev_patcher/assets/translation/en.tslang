        <key name="patch_load_error_title">Error</key>
        <key name="patch_load_error_msg">Failed to read patch file: {}</key>
        <key name="self_update_warning_title">Warning!</key>
        <key name="self_update_warning_msg">This patch is intended to modify the DevPatcher application files. Are you sure you want to continue?</key>
