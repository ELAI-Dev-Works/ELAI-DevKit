        <key name="simulation_success_msg">Simulation complete. Apply this patch to the real files?</key>
        <key name="simulation_error_msg">Errors or conflicts were detected during simulation! Details are in the log. Attempt to apply the patch anyway?</key>
        <key name="test_run_report_title">Test Run Report</key>
        <key name="test_run_report_info">This is the console output from the test launch of your patched application.</key>
        <key name="code_check_error_msg">Syntax errors detected in the patched code! See the report for details. Attempt to apply the patch anyway?</key>
        <key name="corrector_title">Patch Syntax Corrector</key>
        <key name="corrector_info_label">Syntax errors or suggestions were found in your patch. Review the changes below.</key>
